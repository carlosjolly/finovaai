<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">

<style>
/* =====================================================================
   FINOVA AI — Hoja de estilos
   Sistema de diseño: tokens de color, tipografía y layout centralizados
   en :root para evitar reglas duplicadas o que se cancelen entre sí.
   ===================================================================== */

:root{
  /* --- Color --- */
  --navy:#0A2540;
  --navy-deep:#06182B;
  --blue:#3B82F6;
  --blue-light:#60A5FA;
  --emerald:#10B981;
  --emerald-light:#34D399;
  --white:#FFFFFF;
  --bg-soft:#F6F9FC;
  --slate:#54657B;
  --slate-light:#8A97AB;
  --border:#E3E8F0;
  --gradient-brand:linear-gradient(135deg, var(--blue) 0%, var(--emerald) 100%);

  /* --- Tipografia --- */
  --font-display:'Sora', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --font-body:'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --font-mono:'JetBrains Mono', 'SFMono-Regular', Menlo, Consolas, monospace;

  /* --- Layout --- */
  --max:1200px;
  --radius-sm:10px;
  --radius-md:16px;
  --radius-lg:24px;
  --shadow-sm:0 2px 10px rgba(10,37,64,.06);
  --shadow-md:0 10px 30px rgba(10,37,64,.10);
  --shadow-lg:0 28px 60px rgba(10,37,64,.16);
  --ease:cubic-bezier(.16,1,.3,1);
  --nav-h:76px;
}

/* --- Reset --- */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;}
body{
  font-family:var(--font-body);
  color:var(--navy);
  background:var(--white);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
img,svg{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}
button{font:inherit;color:inherit;background:none;border:none;cursor:pointer;}
ul{list-style:none;}
input,textarea{font:inherit;color:inherit;}
h1,h2,h3,h4{font-family:var(--font-display);font-weight:700;line-height:1.15;letter-spacing:-0.01em;}

/* --- Utilidades --- */
.wrap{max-width:var(--max);margin-inline:auto;padding-inline:24px;}
.section{padding-block:clamp(64px,9vw,112px);}
.section-head{max-width:640px;margin-bottom:clamp(40px,6vw,64px);}
.eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:.8125rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;
  color:var(--blue);background:rgba(59,130,246,.08);
  padding:7px 14px;border-radius:999px;margin-bottom:18px;
}
.eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--emerald);}
.section-head h2{font-size:clamp(1.9rem,1.3rem + 2.4vw,2.75rem);color:var(--navy);margin-bottom:14px;}
.section-head p{font-size:1.0625rem;color:var(--slate);max-width:54ch;}
.center{text-align:center;margin-inline:auto;}
.icon{width:1em;height:1em;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;}
.grad-text{
  background:var(--gradient-brand);
  -webkit-background-clip:text;background-clip:text;color:var(--blue);
  -webkit-text-fill-color:transparent;
}
.skip-link{
  position:absolute;left:-999px;top:0;background:var(--navy);color:var(--white);
  padding:10px 18px;border-radius:0 0 8px 0;z-index:200;font-weight:600;
}
.skip-link:focus{left:0;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;border-radius:4px;}

/* --- Botones --- */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  font-family:var(--font-body);font-weight:600;font-size:.9375rem;
  padding:14px 26px;border-radius:999px;
  transition:transform .25s var(--ease), box-shadow .25s var(--ease), background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  white-space:nowrap;
}
.btn-primary{
  background:var(--white);color:var(--navy);
  box-shadow:0 1px 0 rgba(255,255,255,.4) inset, 0 12px 30px rgba(0,0,0,.18);
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 1px 0 rgba(255,255,255,.4) inset, 0 16px 34px rgba(0,0,0,.24);}
.btn-solid{background:var(--gradient-brand);color:var(--white);box-shadow:0 14px 28px rgba(16,185,129,.22);}
.btn-solid:hover{transform:translateY(-2px);box-shadow:0 18px 32px rgba(16,185,129,.3);}
.btn-secondary{
  background:rgba(255,255,255,.06);color:var(--white);
  border:1.5px solid rgba(255,255,255,.35);
}
.btn-secondary:hover{background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.6);transform:translateY(-2px);}
.btn-outline{background:transparent;color:var(--navy);border:1.5px solid var(--border);}
.btn-outline:hover{border-color:var(--blue);color:var(--blue);}
.btn-block{width:100%;}

/* =====================================================================
   NAV
   ===================================================================== */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  height:var(--nav-h);display:flex;align-items:center;
  background:rgba(255,255,255,0);
  transition:background .35s var(--ease), box-shadow .35s var(--ease), border-color .35s var(--ease);
  border-bottom:1px solid transparent;
}
.nav--scrolled{background:rgba(255,255,255,.85);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom-color:var(--border);box-shadow:0 4px 20px rgba(10,37,64,.05);}
.nav__inner{display:flex;align-items:center;justify-content:space-between;width:100%;}

/* Arriba de todo el nav es transparente y queda sobre el Hero oscuro,
   por eso logo/links/botones parten en blanco. Al hacer scroll, el nav
   adquiere fondo claro (.nav--scrolled) y todo pasa a navy. */
.brand{display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:700;font-size:1.15rem;color:var(--white);transition:color .35s var(--ease);}
.nav--scrolled .brand{color:var(--navy);}
.brand__mark{
  width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,.16);
  display:flex;align-items:center;justify-content:center;color:var(--emerald-light);flex-shrink:0;
  transition:background .35s var(--ease);
}
.nav--scrolled .brand__mark{background:var(--navy);}
.brand__mark .icon{width:18px;height:18px;}
.nav__links{display:flex;align-items:center;gap:36px;}
.nav__links a{font-size:.9375rem;font-weight:500;color:rgba(255,255,255,.92);position:relative;padding-block:6px;transition:color .35s var(--ease);}
.nav--scrolled .nav__links a{color:var(--navy);}
.nav__links a::after{
  content:"";position:absolute;left:0;right:0;bottom:0;height:2px;border-radius:2px;
  background:var(--gradient-brand);transform:scaleX(0);transform-origin:left;transition:transform .3s var(--ease);
}
.nav__links a:hover::after,.nav__links a.is-active::after{transform:scaleX(1);}
.nav__cta{display:flex;align-items:center;gap:14px;}
.nav__cta .btn:not(.btn-outline){padding:11px 22px;background:var(--white);color:var(--navy);box-shadow:0 6px 16px rgba(0,0,0,.18);}
.nav__cta .btn:not(.btn-outline):hover{transform:translateY(-2px);box-shadow:0 10px 22px rgba(0,0,0,.24);}
.nav--scrolled .nav__cta .btn:not(.btn-outline){background:var(--navy);color:var(--white);box-shadow:none;}
.nav--scrolled .nav__cta .btn:not(.btn-outline):hover{background:var(--navy-deep);}
.nav__cta .btn-outline{color:var(--white);border-color:rgba(255,255,255,.45);}
.nav__cta .btn-outline:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.75);color:var(--white);}
.nav--scrolled .nav__cta .btn-outline{color:var(--navy);border-color:var(--border);}
.nav--scrolled .nav__cta .btn-outline:hover{background:transparent;border-color:var(--blue);color:var(--blue);}
.nav__toggle{display:none;width:42px;height:42px;align-items:center;justify-content:center;border-radius:10px;color:var(--white);transition:color .35s var(--ease);}
.nav--scrolled .nav__toggle{color:var(--navy);}
.nav__toggle .icon{width:22px;height:22px;}
.nav__toggle .icon-close{display:none;}
.nav.is-open .nav__toggle .icon-menu{display:none;}
.nav.is-open .nav__toggle .icon-close{display:block;}

/* =====================================================================
   HERO
   ===================================================================== */
.hero{
  position:relative;padding-top:calc(var(--nav-h) + 64px);padding-bottom:60px;
  background:radial-gradient(ellipse 80% 60% at 80% -10%, #11305a 0%, var(--navy) 55%), var(--navy);
  color:var(--white);overflow:hidden;
}
.hero::before,.hero::after{
  content:"";position:absolute;border-radius:50%;filter:blur(70px);opacity:.35;pointer-events:none;
}
.hero::before{width:480px;height:480px;background:var(--blue);top:-160px;right:-120px;}
.hero::after{width:420px;height:420px;background:var(--emerald);bottom:-200px;left:-140px;opacity:.25;}
.hero__grid{
  position:relative;z-index:1;display:grid;grid-template-columns:1.05fr 1fr;gap:48px;align-items:center;
}
.hero__copy{max-width:560px;}
.hero__copy .eyebrow{background:rgba(255,255,255,.08);color:var(--emerald-light);}
.hero__copy .eyebrow .dot{background:var(--blue-light);}
.hero__title{font-size:clamp(2.35rem,1.5rem + 3.4vw,3.7rem);margin-bottom:20px;}
.hero__subtitle{font-size:1.125rem;color:rgba(255,255,255,.78);max-width:48ch;margin-bottom:32px;}
.hero__actions{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:22px;}
.hero__trust{font-size:.875rem;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:8px;}
.hero__trust .icon{width:15px;height:15px;color:var(--emerald-light);}

/* --- Tarjeta de producto (elemento de firma) --- */
.insight{position:relative;}
.insight__card{
  position:relative;background:var(--white);color:var(--navy);
  border-radius:var(--radius-lg);padding:26px;width:min(100%,400px);margin-inline:auto;
  box-shadow:var(--shadow-lg);
}
.insight__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;}
.insight__user{display:flex;align-items:center;gap:10px;}
.insight__avatar{
  width:38px;height:38px;border-radius:50%;background:var(--gradient-brand);
  color:var(--white);display:flex;align-items:center;justify-content:center;
  font-family:var(--font-display);font-weight:700;font-size:.8125rem;
}
.insight__user span{display:block;font-size:.9375rem;font-weight:600;}
.insight__user small{display:block;font-size:.75rem;color:var(--slate-light);}
.insight__bell{width:34px;height:34px;border-radius:50%;background:var(--bg-soft);display:flex;align-items:center;justify-content:center;color:var(--slate);}
.insight__bell .icon{width:16px;height:16px;}
.insight__balance-label{font-size:.8125rem;color:var(--slate);margin-bottom:6px;}
.insight__balance-row{display:flex;align-items:baseline;gap:12px;margin-bottom:20px;}
.insight__balance{font-family:var(--font-mono);font-size:1.9rem;font-weight:600;letter-spacing:-.01em;}
.insight__delta{
  font-family:var(--font-mono);font-size:.75rem;font-weight:600;color:var(--emerald);
  background:rgba(16,185,129,.1);padding:4px 9px;border-radius:999px;white-space:nowrap;
}
.insight__chips{display:flex;flex-direction:column;gap:10px;margin-bottom:22px;}
.chip{
  display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;
  background:var(--bg-soft);font-size:.8125rem;
  opacity:0;transform:translateY(8px);
}
html.js .chip{animation:chip-in .55s var(--ease) forwards;}
.chip:nth-child(1){animation-delay:.55s;}
.chip:nth-child(2){animation-delay:.85s;}
.chip:nth-child(3){animation-delay:1.15s;}
@keyframes chip-in{to{opacity:1;transform:translateY(0);}}
.chip__dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.chip--food .chip__dot{background:var(--blue);}
.chip--home .chip__dot{background:var(--navy);}
.chip--income .chip__dot{background:var(--emerald);}
.chip__label{flex:1;font-weight:500;color:var(--navy);}
.chip__amount{font-family:var(--font-mono);font-weight:600;color:var(--slate);}
.chip__check{width:14px;height:14px;color:var(--emerald);flex-shrink:0;}
.insight__goal{display:flex;align-items:center;gap:14px;padding-top:18px;border-top:1px solid var(--border);}
.insight__ring{position:relative;width:54px;height:54px;flex-shrink:0;}
.insight__ring svg{width:100%;height:100%;transform:rotate(-90deg);}
.insight__ring circle{fill:none;stroke-width:5;}
.insight__ring .track{stroke:var(--border);}
.insight__ring .progress{
  stroke:var(--emerald);stroke-linecap:round;stroke-dasharray:138;stroke-dashoffset:138;
}
html.js .insight__ring .progress{transition:stroke-dashoffset 1.4s var(--ease) 1.3s;}
.insight.is-revealed .insight__ring .progress{stroke-dashoffset:44;}
.insight__goal-text strong{display:block;font-size:.875rem;font-weight:600;}
.insight__goal-text span{font-size:.75rem;color:var(--slate-light);}
.insight__badge{
  position:absolute;top:-18px;right:18px;background:var(--white);color:var(--navy);
  display:flex;align-items:center;gap:8px;padding:9px 14px;border-radius:999px;
  font-size:.75rem;font-weight:600;box-shadow:var(--shadow-md);z-index:2;
}
.insight__badge .pulse{width:8px;height:8px;border-radius:50%;background:var(--emerald);position:relative;}
html.js .insight__badge .pulse::after{
  content:"";position:absolute;inset:-4px;border-radius:50%;border:2px solid var(--emerald);
  animation:pulse 2s ease-out infinite;
}
@keyframes pulse{0%{transform:scale(.5);opacity:1;}100%{transform:scale(1.8);opacity:0;}}

/* --- Beneficios --- */
.benefits{background:var(--bg-soft);padding-block:40px;border-bottom:1px solid var(--border);}
.benefits__row{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.benefit{display:flex;align-items:center;gap:14px;}
.benefit__icon{
  width:44px;height:44px;border-radius:12px;background:var(--white);box-shadow:var(--shadow-sm);
  display:flex;align-items:center;justify-content:center;color:var(--blue);flex-shrink:0;
}
.benefit:nth-child(2) .benefit__icon{color:var(--emerald);}
.benefit:nth-child(4) .benefit__icon{color:var(--navy);}
.benefit__icon .icon{width:20px;height:20px;}
.benefit p{font-size:.875rem;font-weight:600;color:var(--navy);}

/* =====================================================================
   STATS
   ===================================================================== */
.stats{background:var(--navy);color:var(--white);}
.stats__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;text-align:center;}
.stat__num{font-family:var(--font-mono);font-size:clamp(2.1rem,1.6rem + 2vw,2.9rem);font-weight:600;color:var(--emerald-light);}
.stat__label{margin-top:8px;font-size:.875rem;color:rgba(255,255,255,.65);}

/* =====================================================================
   SOBRE NOSOTROS
   ===================================================================== */
.about__grid{display:grid;grid-template-columns:1.1fr .9fr;gap:64px;align-items:start;}
.about__story p{color:var(--slate);margin-bottom:16px;font-size:1.0625rem;}
.about__cards{display:flex;flex-direction:column;gap:20px;}
.mv-card{
  background:var(--bg-soft);border-radius:var(--radius-md);padding:26px;
  border-left:3px solid var(--blue);
}
.mv-card:nth-child(2){border-left-color:var(--emerald);}
.mv-card__icon{
  width:38px;height:38px;border-radius:10px;background:var(--white);box-shadow:var(--shadow-sm);
  display:flex;align-items:center;justify-content:center;color:var(--blue);margin-bottom:14px;
}
.mv-card:nth-child(2) .mv-card__icon{color:var(--emerald);}
.mv-card__icon .icon{width:18px;height:18px;}
.mv-card h3{font-size:1.0625rem;margin-bottom:8px;}
.mv-card p{color:var(--slate);font-size:.9375rem;}
.values{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-top:48px;}
.value{
  text-align:center;padding:22px 14px;border-radius:var(--radius-md);border:1px solid var(--border);
  transition:transform .3s var(--ease), box-shadow .3s var(--ease), border-color .3s var(--ease);
}
.value:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:transparent;}
.value__icon{
  width:46px;height:46px;border-radius:50%;background:var(--bg-soft);margin-inline:auto;margin-bottom:12px;
  display:flex;align-items:center;justify-content:center;color:var(--blue);
}
.value:nth-child(2) .value__icon{color:var(--emerald);}
.value:nth-child(3) .value__icon{color:var(--navy);}
.value:nth-child(4) .value__icon{color:var(--blue);}
.value:nth-child(5) .value__icon{color:var(--emerald);}
.value__icon .icon{width:20px;height:20px;}
.value h4{font-size:.875rem;font-weight:600;}

/* =====================================================================
   SERVICIOS
   ===================================================================== */
.services{background:var(--bg-soft);}
.services__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.service-card{
  background:var(--white);border-radius:var(--radius-lg);padding:32px;
  border:1px solid var(--border);transition:transform .35s var(--ease), box-shadow .35s var(--ease), border-color .35s var(--ease);
  display:flex;flex-direction:column;height:100%;
}
.service-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:transparent;}
.service-card__icon{
  width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;
  margin-bottom:20px;color:var(--white);background:var(--gradient-brand);
}
.service-card:nth-child(2n) .service-card__icon{background:linear-gradient(135deg, var(--navy), var(--blue));}
.service-card__icon .icon{width:24px;height:24px;}
.service-card h3{font-size:1.1875rem;margin-bottom:10px;}
.service-card p{color:var(--slate);font-size:.9375rem;flex-grow:1;margin-bottom:18px;}
.service-card__link{display:inline-flex;align-items:center;gap:6px;font-size:.875rem;font-weight:600;color:var(--blue);}
.service-card__link .icon{width:15px;height:15px;transition:transform .25s var(--ease);}
.service-card__link:hover .icon{transform:translateX(3px);}

/* =====================================================================
   TESTIMONIOS
   ===================================================================== */
.testimonials__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.t-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;}
.t-card__quote{color:var(--navy);font-size:.9375rem;margin-bottom:22px;}
.t-card__person{display:flex;align-items:center;gap:12px;}
.t-card__avatar{
  width:42px;height:42px;border-radius:50%;background:var(--navy);color:var(--emerald-light);
  display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.8125rem;flex-shrink:0;
}
.t-card:nth-child(2) .t-card__avatar{background:var(--blue);color:var(--white);}
.t-card:nth-child(3) .t-card__avatar{background:var(--emerald);color:var(--navy);}
.t-card__person strong{display:block;font-size:.875rem;}
.t-card__person span{font-size:.8125rem;color:var(--slate-light);}

/* =====================================================================
   FAQ
   ===================================================================== */
.faq{background:var(--bg-soft);}
.faq__list{max-width:760px;margin-inline:auto;display:flex;flex-direction:column;gap:12px;}
.faq-item{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);overflow:hidden;}
.faq-item__q{
  width:100%;display:flex;align-items:center;justify-content:space-between;gap:16px;
  padding:20px 22px;text-align:left;font-family:var(--font-display);font-weight:600;font-size:1rem;
}
.faq-item__q .icon{width:18px;height:18px;color:var(--slate);flex-shrink:0;transition:transform .3s var(--ease);}
.faq-item.is-open .faq-item__q .icon{transform:rotate(180deg);color:var(--blue);}
.faq-item__wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows .35s var(--ease);}
.faq-item.is-open .faq-item__wrap{grid-template-rows:1fr;}
.faq-item__a{overflow:hidden;min-height:0;}
.faq-item__a p{padding:0 22px 20px;color:var(--slate);font-size:.9375rem;max-width:62ch;}

/* =====================================================================
   CONTACTO
   ===================================================================== */
.contact__grid{display:grid;grid-template-columns:1.1fr .8fr;gap:48px;}
.contact-panel{background:var(--bg-soft);border-radius:var(--radius-lg);padding:clamp(28px,4vw,42px);}
.field{margin-bottom:18px;}
.field label{display:block;font-size:.875rem;font-weight:600;margin-bottom:7px;}
.field input,.field textarea{
  width:100%;padding:13px 16px;border-radius:10px;border:1px solid var(--border);
  background:var(--white);font-size:.9375rem;transition:border-color .25s var(--ease), box-shadow .25s var(--ease);
}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,130,246,.15);}
.field textarea{min-height:110px;resize:vertical;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.segmented{display:flex;gap:10px;}
.segmented input{position:absolute;opacity:0;pointer-events:none;}
.segmented label{
  flex:1;text-align:center;padding:12px;border-radius:10px;border:1px solid var(--border);
  background:var(--white);font-size:.9375rem;font-weight:500;cursor:pointer;
  transition:border-color .25s var(--ease), background .25s var(--ease), color .25s var(--ease);
}
.segmented input:checked + label{border-color:var(--blue);background:rgba(59,130,246,.08);color:var(--blue);font-weight:600;}
.segmented input:focus-visible + label{outline:2px solid var(--blue);outline-offset:2px;}
.form-success{display:flex;flex-direction:column;align-items:flex-start;gap:16px;padding:20px 0;}
.form-success__icon{width:54px;height:54px;border-radius:50%;background:rgba(16,185,129,.12);color:var(--emerald);display:flex;align-items:center;justify-content:center;}
.form-success__icon .icon{width:26px;height:26px;}
.form-success h3{font-size:1.25rem;}
.form-success p{color:var(--slate);max-width:46ch;}

.contact-info{display:flex;flex-direction:column;gap:18px;}
.info-card{background:var(--navy);color:var(--white);border-radius:var(--radius-lg);padding:28px;}
.info-card h3{font-size:1.1rem;margin-bottom:6px;}
.info-card p{color:rgba(255,255,255,.7);font-size:.9375rem;margin-bottom:20px;}
.info-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-top:1px solid rgba(255,255,255,.12);}
.info-row:first-of-type{border-top:none;}
.info-row__icon{width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;color:var(--emerald-light);flex-shrink:0;}
.info-row__icon .icon{width:16px;height:16px;}
.info-row a, .info-row span{font-size:.9375rem;font-weight:500;}
.info-card--light{background:var(--white);border:1px solid var(--border);color:var(--navy);}
.info-card--light p{color:var(--slate);}
.info-card--light .info-row{border-top-color:var(--border);}
.info-card--light .info-row__icon{background:var(--bg-soft);color:var(--blue);}

/* =====================================================================
   FOOTER
   ===================================================================== */
.footer{background:var(--navy-deep);color:rgba(255,255,255,.7);padding-block:64px 28px;}
.footer__top{display:grid;grid-template-columns:1.4fr .8fr .8fr .8fr;gap:40px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,.1);}
.footer__brand .brand{color:var(--white);margin-bottom:14px;}
.footer__brand .brand__mark{background:rgba(255,255,255,.08);}
.footer__brand p{font-size:.9375rem;max-width:32ch;margin-bottom:20px;}
.social{display:flex;gap:10px;}
.social a{
  width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.06);
  display:flex;align-items:center;justify-content:center;transition:background .25s var(--ease), transform .25s var(--ease);
}
.social a:hover{background:var(--gradient-brand);transform:translateY(-3px);}
.social .icon{width:16px;height:16px;}
.footer__col h4{font-family:var(--font-display);color:var(--white);font-size:.9375rem;margin-bottom:18px;}
.footer__col ul{display:flex;flex-direction:column;gap:12px;}
.footer__col a{font-size:.9375rem;transition:color .2s var(--ease);}
.footer__col a:hover{color:var(--white);}
.footer__bottom{display:flex;justify-content:space-between;align-items:center;padding-top:24px;font-size:.8125rem;flex-wrap:wrap;gap:10px;}

/* =====================================================================
   REVEAL AL HACER SCROLL
   ===================================================================== */
html.js .reveal{opacity:0;transform:translateY(26px);transition:opacity .7s var(--ease), transform .7s var(--ease);}
html.js .reveal.is-visible{opacity:1;transform:translateY(0);}
html.js .hero__copy > *{opacity:0;transform:translateY(16px);}
html.js .hero.is-loaded .hero__copy > *{
  opacity:1;transform:translateY(0);
  transition:opacity .7s var(--ease), transform .7s var(--ease);
}
html.js .hero__copy > *:nth-child(1){transition-delay:.05s;}
html.js .hero__copy > *:nth-child(2){transition-delay:.15s;}
html.js .hero__copy > *:nth-child(3){transition-delay:.25s;}
html.js .hero__copy > *:nth-child(4){transition-delay:.35s;}
html.js .insight{opacity:0;transform:translateY(20px) scale(.97);transition:opacity .8s var(--ease) .2s, transform .8s var(--ease) .2s;}
html.js .hero.is-loaded .insight{opacity:1;transform:translateY(0) scale(1);}

/* =====================================================================
   RESPONSIVE
   ===================================================================== */
@media (max-width:1024px){
  .hero__grid{grid-template-columns:1fr;gap:56px;}
  .hero__copy{max-width:640px;margin-inline:auto;text-align:center;}
  .hero__actions,.hero__trust{justify-content:center;}
  .insight__badge{right:50%;transform:translateX(150px);}
  .about__grid{grid-template-columns:1fr;gap:40px;}
  .values{grid-template-columns:repeat(3,1fr);}
  .services__grid{grid-template-columns:repeat(2,1fr);}
  .testimonials__grid{grid-template-columns:1fr 1fr;}
  .contact__grid{grid-template-columns:1fr;}
  .footer__top{grid-template-columns:1.2fr 1fr 1fr;}
}
@media (max-width:760px){
  .nav__links{
    position:absolute;top:var(--nav-h);left:0;right:0;background:var(--white);
    flex-direction:column;align-items:stretch;gap:0;padding:8px 24px 20px;
    box-shadow:0 12px 24px rgba(10,37,64,.08);border-bottom:1px solid var(--border);
    max-height:0;overflow:hidden;transition:max-height .35s var(--ease);
  }
  .nav.is-open .nav__links{max-height:340px;}
  /* El desplegable mobile siempre tiene fondo blanco, con o sin scroll */
  .nav__links a{color:var(--navy);padding:14px 0;border-bottom:1px solid var(--border);}
  .nav__links a:last-child{border-bottom:none;}
  .nav__cta .btn-outline{display:none;}
  .nav__toggle{display:flex;}
  .benefits__row{grid-template-columns:repeat(2,1fr);}
  .stats__grid{grid-template-columns:repeat(2,1fr);gap:28px;}
  .values{grid-template-columns:repeat(2,1fr);}
  .services__grid{grid-template-columns:1fr;}
  .testimonials__grid{grid-template-columns:1fr;}
  .footer__top{grid-template-columns:1fr;gap:32px;}
  .field-row{grid-template-columns:1fr;}
  .insight__badge{position:static;display:inline-flex;margin-bottom:14px;transform:none;}
}
@media (max-width:480px){
  .wrap{padding-inline:18px;}
  .hero__actions{flex-direction:column;width:100%;}
  .hero__actions .btn{width:100%;}
}

/* --- Respeto por reduce-motion --- */
@media (prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important;scroll-behavior:auto!important;}
  html.js .reveal,html.js .hero__copy > *,html.js .insight,.chip{opacity:1!important;transform:none!important;}
}
</style>
</head>
